# Keep the packaged .vsix lean: ship only runtime files.
# Included by default (do NOT list): package.json, README.md, LICENSE,
# assets/zenkai.png, themes/zenkai-*.json, dist/extension.js, dist/lib/**

# TypeScript sources (compiled into dist/ at build time)
**/*.ts
!**/*.d.ts
palettes/

# Tests (source and compiled)
test/**
dist/test/**

# Build-only entrypoint and sourcemaps, not needed at runtime
dist/build.js
dist/**/*.map

# Tooling / configs
tsconfig*.json
.gitignore
.gitattributes
.editorconfig
.prettierrc
.prettierignore
.vscode/**

# Package manager / scratch
node_modules/**
package-lock.json
**/*.vsix
theme-references/**
docs/**

# OS noise
.DS_Store
Thumbs.db
