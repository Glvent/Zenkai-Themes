{
  "manifest_version": 3,
  "name": "Zenkai Graphite",
  "short_name": "Zenkai",
  "version": "1.0.0",
  "version_name": "1.0",
  "description": "Zenkai Graphite - A muted graphite dark theme with neutral accents.",
  "minimum_chrome_version": "88",
  "theme": {
    "colors": {
      "background_tab": [28, 28, 28],
      "background_tab_inactive": [28, 28, 28],
      "background_tab_incognito": [28, 28, 28],
      "background_tab_incognito_inactive": [28, 28, 28],

      "bookmark_text": [250, 250, 250],
      "button_background": [28, 28, 28],

      "frame": [28, 28, 28],
      "frame_inactive": [28, 28, 28],
      "frame_incognito": [28, 28, 28],
      "frame_incognito_inactive": [28, 28, 28],

      "ntp_background": [28, 28, 28],
      "ntp_header": [250, 250, 250],
      "ntp_link": [200, 200, 200],
      "ntp_text": [250, 250, 250],

      "omnibox_background": [56, 56, 56],
      "omnibox_text": [250, 250, 250],

      "tab_background_text": [200, 200, 200],
      "tab_background_text_inactive": [175, 175, 175],
      "tab_background_text_incognito": [200, 200, 200],
      "tab_background_text_incognito_inactive": [175, 175, 175],
      "tab_text": [250, 250, 250],

      "toolbar": [36, 36, 36],
      "toolbar_button_icon": [200, 200, 200],
      "toolbar_text": [250, 250, 250]
    },
    "tints": {
      "background_tab": [-1, -1, -1],
      "buttons": [-1, -1, -1],
      "frame": [-1, -1, -1],
      "frame_inactive": [-1, -1, -1],
      "frame_incognito": [-1, -1, -1],
      "frame_incognito_inactive": [-1, -1, -1]
    },
    "properties": {
      "ntp_background_alignment": "center",
      "ntp_background_repeat": "no-repeat",
      "ntp_logo_alternate": 1
    }
  }
}
