{
  "files.exclude": {
    "**/.git": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/.DS_Store": true,
    "**/Thumbs.db": true,
    "**/node_modules": true,
    "**/dist": true,
    "**/out": true,
    "**/.theme-build": true,
    "**/coverage": true,
    "**/*.tsbuildinfo": true,
    "**/package-lock.json": true,
    "**/.editorconfig": true,
    "**/.gitattributes": true,
    "**/.prettierrc": true,
    "**/.prettierignore": true,
    "**/.vscodeignore": true,
    "**/.cursorignore": true,
    "**/.npmrc": true,
    "**/.trunk": true
  },
  // Keep the file watcher off heavy / generated trees to cut CPU and noise.
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/**": true,
    "**/dist/**": true,
    "**/out/**": true,
    "**/.theme-build/**": true,
    "**/coverage/**": true,
    "**/*.vsix": true,
    "**/*.tsbuildinfo": true
  }
}
